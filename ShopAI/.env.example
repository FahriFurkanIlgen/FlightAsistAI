# Server Configuration
PORT=3000
NODE_ENV=development

# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4-turbo-preview

# Cache Configuration
CACHE_TTL_SECONDS=3600
FEED_UPDATE_CRON=0 * * * *

# Flight Data Configuration
# Flight feed URL (currently using mock data)
FLIGHT_FEED_URL=mock
SITE_NAME=SunExpress

# CORS Configuration
# Allow multiple origins separated by commas, or use * for all origins (not recommended for production)
ALLOWED_ORIGINS=http://localhost:3001,http://127.0.0.1:3001,http://localhost:5500

# Logging
LOG_LEVEL=info

# Neo4j GraphDB Configuration (Optional - for flight relationships)
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password_here
NEO4J_ENABLED=false
